# 사주 API 환경 변수 예시
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env

# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# 애플리케이션 설정 (선택)
# APP_NAME=사주 API
# APP_VERSION=0.1.0
# DEBUG=false

# CORS 설정 (선택, 기본값: ["*"])
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]
